---
// Header.astro — Y2K Pija × Silent Hill
// "Mean Girls meets Silent Hill" — Estética 2000s horror glam
const navItems = [
  { label: "HOME", href: "/" },
  { label: "GAMES", href: "/games" },
  { label: "ABOUT", href: "/about" },
  { label: "BLOG", href: "/blog" },
];
---

<header class="header-root">
  <!-- CRT Scanline overlay -->
  <div class="crt-overlay" aria-hidden="true"></div>

  <!-- Glitter / noise background layer -->
  <div class="glitter-bg" aria-hidden="true"></div>

  <!-- Main container: glassmorphism bubble -->
  <div class="header-glass">

    <!-- Left: decorative Y2K butterflies / stars -->
    <div class="deco-left" aria-hidden="true">
      <span class="deco-star">✦</span>
      <span class="deco-skull">☠</span>
      <span class="deco-star small">✦</span>
    </div>

    <!-- Center: Logo + Nav -->
    <div class="center-col">

      <!-- LOGO -->
      <a href="/" class="logo-link" aria-label="Home">
        <span class="logo-text" data-text="CRIMSON PINK">Mom! My dollhouse is acting weird!</span>
      </a>

      <!-- NAV -->
      <nav aria-label="Main navigation">
        <ul class="nav-list">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="nav-link">
                <span class="nav-icon nav-heart" aria-hidden="true">♥</span>
                <span class="nav-icon nav-horror" aria-hidden="true">☠</span>
                <span class="nav-label">{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

    </div>

    <!-- Right: PLAY NOW button -->
    <div class="deco-right" aria-hidden="false">
      <a href="/play" class="play-btn" aria-label="Play Now">
        PLAY NOW
      </a>
    </div>

  </div>
</header>

<style>
  /* ─── Custom properties ──────────────────────────────────── */
  :root {
    --pink-hot:    #FF69B4;
    --pink-neon:   #FF1493;
    --pink-pastel: #FFB6C1;
    --pink-light:  #FFC0CB;
    --white:       #FFFFFF;
    --black:       #0A0A0A;
    --blood:       #8B0000;
    --glass-bg:    rgba(255, 105, 180, 0.18);
    --glass-border:rgba(255, 255, 255, 0.45);
    --shadow-pink: 4px 4px 0px #8B0000, 8px 8px 0px #000;
  }

  /* ─── Google Fonts ──────────────────────────────────────── */
  @import url('https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Press+Start+2P&family=Playfair+Display:ital,wght@1,700&display=swap');

  /* ─── Root header ───────────────────────────────────────── */
  .header-root {
    position: relative;
    width: 100%;
    padding: 0.75rem 1rem;
    overflow: hidden;    box-sizing: border-box;    background: linear-gradient(
      135deg,
      #1a0010 0%,
      #2d0020 25%,
      #1a0010 50%,
      #0d000a 75%,
      #1a0010 100%
    );
  }

  /* ─── Glitter background ─────────────────────────────────── */
  .glitter-bg {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(255,105,180,0.35) 0%, transparent 40%),
      radial-gradient(circle at 80% 70%, rgba(255,20,147,0.25) 0%, transparent 40%),
      radial-gradient(circle at 50% 50%, rgba(255,182,193,0.1) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* ─── CRT Scanlines overlay ──────────────────────────────── */
  .crt-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px,
      transparent 3px,
      rgba(0, 0, 0, 0.18) 3px,
      rgba(0, 0, 0, 0.18) 4px
    );
    animation: crt-flicker 8s infinite;
  }

  @keyframes crt-flicker {
    0%, 98%, 100% { opacity: 1; }
    99% { opacity: 0.82; }
  }

  /* ─── Glassmorphism bubble container ─────────────────────── */
  .header-glass {
    position: relative;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    background: var(--glass-bg);
    border: 2.5px solid var(--glass-border);
    border-radius: 24px;
    backdrop-filter: blur(12px) saturate(1.8);
    -webkit-backdrop-filter: blur(12px) saturate(1.8);
    box-shadow:
      0 0 0 1px rgba(255,105,180,0.3),
      0 8px 32px rgba(255,20,147,0.25),
      inset 0 1px 0 rgba(255,255,255,0.5),
      inset 0 -1px 0 rgba(255,105,180,0.2);
  }

  /* ─── Decorative elements ────────────────────────────────── */
  .deco-left,
  .deco-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .deco-star {
    font-size: 1.2rem;
    color: var(--pink-hot);
    text-shadow: 0 0 8px var(--pink-neon), 0 0 16px rgba(255,105,180,0.5);
    animation: star-pulse 2s ease-in-out infinite alternate;
  }
  .deco-star.small { font-size: 1.2rem; animation-delay: 0.5s; }

  .deco-skull {
    font-size: 1.2rem;
    color: var(--pink-pastel);
    opacity: 0.7;
    animation: skull-float 3s ease-in-out infinite;
  }

  @keyframes star-pulse {
    from { transform: scale(1) rotate(-5deg); opacity: 0.8; }
    to   { transform: scale(1.2) rotate(5deg); opacity: 1; }
  }

  @keyframes skull-float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-4px); }
  }

  /* ─── Center column ──────────────────────────────────────── */
  .center-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    flex: 1;
  }

  /* ─── Logo ───────────────────────────────────────────────── */
  .logo-link {
    text-decoration: none;
    display: block;
    position: relative;
  }

  .logo-text {
    font-family: 'Dancing Script', 'Playfair Display', cursive;
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--white);
    letter-spacing: 0.04em;
    position: relative;
    display: inline-block;
    text-shadow:
      0 0 10px var(--pink-hot),
      0 0 20px var(--pink-neon),
      2px 2px 0 var(--blood);
    animation: glitch-idle 5s infinite;
  }

  /* Glitch pseudo-elements */
  .logo-text::before,
  .logo-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    pointer-events: none;
  }

  .logo-text::before {
    color: var(--pink-neon);
    clip-path: polygon(0 0, 100% 0, 100% 35%, 0 35%);
    animation: glitch-top 5s infinite;
    opacity: 0;
  }

  .logo-text::after {
    color: var(--blood);
    clip-path: polygon(0 65%, 100% 65%, 100% 100%, 0 100%);
    animation: glitch-bottom 5s infinite;
    opacity: 0;
  }

  @keyframes glitch-idle {
    0%, 90%, 100% { transform: translate(0); }
    92% { transform: translate(-2px, 1px); }
    94% { transform: translate(2px, -1px); }
    96% { transform: translate(-1px, 0); }
    98% { transform: translate(0, 1px); }
  }

  @keyframes glitch-top {
    0%, 89%, 100% { opacity: 0; transform: translate(0); }
    90% { opacity: 0.9; transform: translate(-3px, -1px); }
    92% { opacity: 0.9; transform: translate(3px, 1px); }
    94% { opacity: 0; }
  }

  @keyframes glitch-bottom {
    0%, 90%, 100% { opacity: 0; transform: translate(0); }
    91% { opacity: 0.9; transform: translate(3px, 2px); }
    93% { opacity: 0.9; transform: translate(-3px, -1px); }
    95% { opacity: 0; }
  }

  /* ─── Navigation ─────────────────────────────────────────── */
  .nav-list {
    display: flex;
    align-items: center;
    gap: clamp(0.5rem, 2vw, 1.5rem);
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    justify-content: center;
  }

  .nav-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    text-decoration: none;
    padding: 0.25rem 0.4rem;
    transition: transform 0.2s ease;
  }

  .nav-link:hover {
    transform: translateY(-2px);
  }

  /* Icon swap: heart → horror */
  .nav-icon {
    font-size: 0.9rem;
    position: absolute;
    left: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .nav-heart {
    color: var(--pink-hot);
    opacity: 1;
    transform: scale(1);
  }

  .nav-horror {
    color: var(--pink-hot);
    opacity: 0;
    transform: scale(0.5);
    text-shadow: 0 0 6px #ff0000;
  }

  .nav-link:hover .nav-heart {
    opacity: 0;
    transform: scale(1.5);
  }

  .nav-link:hover .nav-horror {
    opacity: 1;
    transform: scale(1.2);
  }

  .nav-label {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(0.45rem, 1.2vw, 0.6rem);
    color: var(--pink-pastel);
    letter-spacing: 0.08em;
    padding-left: 1.2rem;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }

  .nav-link:hover .nav-label {
    color: var(--white);
    text-shadow: 0 0 8px var(--pink-neon);
  }

  /* ─── PLAY NOW button ────────────────────────────────────── */
  .play-btn {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(0.5rem, 1.1vw, 0.65rem);
    color: var(--black);
    background: var(--pink-neon);
    border: 2px solid var(--white);
    padding: 0.65rem 0.9rem;
    text-decoration: none;
    display: inline-block;
    letter-spacing: 0.05em;
    line-height: 1.4;
    text-align: center;
    white-space: nowrap;

    /* Aggressive drop shadow */
    box-shadow:
      4px 4px 0px #8B0000,
      8px 8px 0px #000000,
      0 0 20px rgba(255,20,147,0.6),
      0 0 40px rgba(255,20,147,0.3);

    transition:
      transform 0.1s ease,
      box-shadow 0.1s ease,
      background 0.2s ease;

    position: relative;
    overflow: hidden;
  }

  /* shimmer sweep */
  .play-btn::before {
    content: '';
    position: absolute;
    top: -50%; left: -75%;
    width: 50%; height: 200%;
    background: rgba(255,255,255,0.35);
    transform: skewX(-20deg);
    animation: shimmer 3s 1s infinite;
  }

  @keyframes shimmer {
    0%   { left: -75%; }
    60%, 100% { left: 125%; }
  }

  .play-btn:hover {
    background: var(--white);
    color: var(--pink-neon);
    transform: translate(-2px, -2px);
    box-shadow:
      6px 6px 0px #8B0000,
      10px 10px 0px #000000,
      0 0 30px rgba(255,20,147,0.9),
      0 0 60px rgba(255,20,147,0.5);
  }

  .play-btn:active {
    transform: translate(4px, 4px);
    box-shadow:
      1px 1px 0px #8B0000,
      2px 2px 0px #000000;
  }

  /* ─── Responsive ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .header-glass {
      flex-direction: column;
      gap: 0.75rem;
      padding: 0.9rem 1rem;
    }

    .deco-left {
      display: none;
    }

    .deco-right {
      flex-direction: row;
      gap: 0.75rem;
    }

    .nav-list {
      gap: 0.5rem;
    }

    .center-col {
      gap: 0.5rem;
    }
  }

  @media (max-width: 480px) {
    .nav-list {
      gap: 0.3rem;
    }

    .nav-label {
      font-size: 0.4rem;
    }

    .logo-text {
      font-size: 1.6rem;
    }
  }
</style>