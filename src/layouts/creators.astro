---

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=VT323&family=Pacifico&family=Share+Tech+Mono&family=Press+Start+2P&display=swap" rel="stylesheet" />

<style>
  :root {
    --pink:        #FF69B4;
    --neon:        #FF1493;
    --pale:        #FFB1D1;
    --blood:       #8B0000;
    --blood-light: #cc0000;
    --deep:        #0a0007;
    --card-bg:     rgba(20, 0, 14, 0.92);
    --white:       #fff;
    --font-pixel:  'Press Start 2P', monospace;
    --font-vt:     'VT323', monospace;
    --font-mono:   'Share Tech Mono', monospace;
    --font-cursi:  'Pacifico', cursive;
  }

  #credits {
    position: relative;
    padding: 5rem 1.5rem 6rem;
    overflow: hidden;
  }

  #credits::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse 18px 12px at 12% 8%,  rgba(255,20,147,.18) 70%, transparent 71%),
      radial-gradient(ellipse 10px 16px at 18% 12%, rgba(255,20,147,.12) 70%, transparent 71%),
      radial-gradient(ellipse 20px 10px at 35% 25%, rgba(255,20,147,.15) 70%, transparent 71%),
      radial-gradient(ellipse 14px 18px at 42% 20%, rgba(255,20,147,.10) 70%, transparent 71%),
      radial-gradient(ellipse 16px 10px at 60% 8%,  rgba(255,20,147,.18) 70%, transparent 71%),
      radial-gradient(ellipse  8px 14px at 67% 14%, rgba(255,20,147,.12) 70%, transparent 71%),
      radial-gradient(ellipse 22px 12px at 80% 22%, rgba(255,20,147,.15) 70%, transparent 71%),
      radial-gradient(ellipse 12px 20px at 88% 18%, rgba(255,20,147,.10) 70%, transparent 71%),
      radial-gradient(ellipse 18px 14px at  5% 45%, rgba(255,20,147,.18) 70%, transparent 71%),
      radial-gradient(ellipse 10px 18px at 14% 52%, rgba(255,20,147,.12) 70%, transparent 71%),
      radial-gradient(ellipse 24px 10px at 28% 60%, rgba(255,20,147,.15) 70%, transparent 71%),
      radial-gradient(ellipse 14px 22px at 50% 48%, rgba(255,20,147,.10) 70%, transparent 71%),
      radial-gradient(ellipse 18px 12px at 72% 55%, rgba(255,20,147,.18) 70%, transparent 71%),
      radial-gradient(ellipse  8px 16px at 82% 62%, rgba(255,20,147,.12) 70%, transparent 71%),
      radial-gradient(ellipse 20px 10px at 95% 50%, rgba(255,20,147,.15) 70%, transparent 71%),
      radial-gradient(ellipse 14px 18px at 20% 78%, rgba(255,20,147,.10) 70%, transparent 71%),
      radial-gradient(ellipse 16px 12px at 40% 88%, rgba(255,20,147,.18) 70%, transparent 71%),
      radial-gradient(ellipse 10px 20px at 65% 82%, rgba(255,20,147,.12) 70%, transparent 71%),
      radial-gradient(ellipse 22px 14px at 90% 75%, rgba(255,20,147,.15) 70%, transparent 71%);
    background-size: 200px 200px;
    opacity: 0.6;
    pointer-events: none;
    z-index: 0;
  }

  #credits::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(255,182,193,.9), transparent),
      radial-gradient(1px 1px at 25% 40%, rgba(255,255,255,.8), transparent),
      radial-gradient(2px 2px at 40% 10%, rgba(255,105,180,.9), transparent),
      radial-gradient(1px 1px at 55% 55%, rgba(255,255,255,.7), transparent),
      radial-gradient(2px 2px at 70% 30%, rgba(255,20,147,.8),  transparent),
      radial-gradient(1px 1px at 85% 70%, rgba(255,182,193,.9), transparent),
      radial-gradient(1px 1px at 15% 80%, rgba(255,255,255,.6), transparent),
      radial-gradient(2px 2px at 92% 20%, rgba(255,105,180,.8), transparent),
      radial-gradient(1px 1px at 48% 90%, rgba(255,20,147,.7),  transparent),
      radial-gradient(2px 2px at 60% 75%, rgba(255,255,255,.9), transparent);
    animation: glitter-twinkle 3s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 0;
  }

  .credits-title {
    position: relative;
    z-index: 2;
    font-family: var(--font-cursi);
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    color: var(--pink);
    text-align: center;
    text-shadow:
      0 0 10px var(--neon),
      0 0 30px rgba(255,20,147,.6),
      0 0 60px rgba(255,20,147,.3),
      3px 3px 0 rgba(139,0,0,.5);
    margin-bottom: 0.4rem;
    letter-spacing: 0.04em;
  }

  .credits-sub {
    position: relative;
    z-index: 2;
    font-family: var(--font-vt);
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--pale);
    text-align: center;
    letter-spacing: 0.25em;
    opacity: 0.7;
    margin-bottom: 3.5rem;
  }

  /* ── grid: 4 columnas → 8 miembros quedan 4+4 perfectos ── */
  .crew-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  @media (max-width: 900px)  { .crew-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 600px)  { .crew-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
  @media (max-width: 400px)  { .crew-grid { grid-template-columns: 1fr; } }

  .crew-card {
    background: var(--card-bg);
    border: 2px solid var(--pink);
    border-radius: 6px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    position: relative;
    box-shadow:
      0 0 0 1px rgba(255,105,180,.2),
      0 0 12px rgba(255,20,147,.3),
      inset 0 0 20px rgba(255,20,147,.05);
    transition: transform 0.3s cubic-bezier(.34,1.56,.64,1), box-shadow 0.3s ease;
    overflow: visible;
  }
  .crew-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow:
      0 0 0 2px var(--neon),
      0 0 24px rgba(255,20,147,.5),
      0 12px 30px rgba(0,0,0,.6);
  }

  .crew-card::before {
    content: ' ☆ ☆ 💀 ☆ ☆ ';
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--pink);
    text-shadow: 0 0 6px var(--neon);
    white-space: nowrap;
    background: var(--deep);
    padding: 0 0.5rem;
  }

  .avatar-wrap {
    position: relative;
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    cursor: pointer;
  }
  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 3px solid var(--pink);
    box-shadow: 0 0 10px rgba(255,20,147,.4);
    display: block;
    filter: contrast(1.1) saturate(0.85) brightness(0.9);
    position: relative;
    z-index: 1;
    transition: filter 0.05s steps(1);
  }
  .avatar-scanlines {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px, transparent 2px,
      rgba(0,0,0,.15) 2px, rgba(0,0,0,.15) 3px
    );
  }
  .avatar-wrap:hover .avatar-img {
    animation: avatar-glitch 0.4s steps(1) infinite;
    filter: contrast(1.5) saturate(0) hue-rotate(180deg);
  }
  .avatar-wrap:hover .avatar-scanlines {
    animation: scanline-shift 0.2s steps(1) infinite;
  }

  .crew-name {
    font-family: var(--font-vt);
    font-size: 1.35rem;
    color: var(--pink);
    text-shadow: 0 0 8px var(--neon), 0 0 20px rgba(255,20,147,.5);
    letter-spacing: 0.1em;
    text-align: center;
    line-height: 1.1;
    transition: all 0.05s steps(1);
  }
  .crew-card:hover .crew-name {
    color: #0ff;
    text-shadow: 2px 0 #f0f, -2px 0 #0ff, 0 0 10px #0ff;
  }

  .crew-role {
    font-family: var(--font-mono);
    font-size: 1rem;
    background: var(--neon);
    color: var(--white);
    padding: 0.2rem 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    box-shadow: 2px 2px 0 rgba(0,0,0,.4), 0 0 8px rgba(255,20,147,.4);
    clip-path: polygon(4px 0%, 100% 0%, calc(100% - 4px) 100%, 0% 100%);
  }

  .crew-status {
    font-family: var(--font-vt);
    font-size: 1.2rem;
    color: rgba(255,177,209,.75);
    text-align: center;
    letter-spacing: 0.05em;
    line-height: 1.2;
    font-style: italic;
  }

  .crew-socials {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.2rem;
  }
  .social-btn {
    width: 40px;
    height: 40px;
    background: rgba(255,20,147,.15);
    border: 1px solid var(--pink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.55rem;
    color: var(--pink);
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s, box-shadow 0.15s;
    image-rendering: pixelated;
    font-family: var(--font-mono);
    font-weight: bold;
    box-shadow: 1px 1px 0 rgba(255,20,147,.3), inset 1px 1px 0 rgba(255,255,255,.05);
  }
  .social-btn:hover {
    background: var(--neon);
    color: var(--white);
    box-shadow: 0 0 8px var(--neon), 2px 2px 0 rgba(0,0,0,.5);
  }

 
  @keyframes glitter-twinkle {
    0%   { opacity: 0.4; }
    50%  { opacity: 1;   }
    100% { opacity: 0.5; }
  }
  @keyframes avatar-glitch {
    0%  { clip-path: inset(20% 0 50% 0); transform: translateX(-4px); }
    25% { clip-path: inset(60% 0 10% 0); transform: translateX(4px);  }
    50% { clip-path: inset(5%  0 70% 0); transform: translateX(-2px); }
    75% { clip-path: inset(40% 0 30% 0); transform: translateX(3px);  }
    100%{ clip-path: inset(0);           transform: translateX(0);     }
  }
  @keyframes scanline-shift {
    0%  { background-position: 0 0;   }
    50% { background-position: 0 3px; }
    100%{ background-position: 0 0;   }
  }
  @keyframes name-glitch {
    0%  { transform: translateX(0);    letter-spacing: 0.1em;  }
    20% { transform: translateX(-3px); letter-spacing: 0.3em;  }
    40% { transform: translateX(3px);  letter-spacing: 0em;    }
    60% { transform: translateX(-1px); letter-spacing: 0.2em;  }
    80% { transform: translateX(2px);  letter-spacing: 0.05em; }
    100%{ transform: translateX(0);    letter-spacing: 0.1em;  }
  }
  @keyframes blood-drip {
    0%   { color: var(--blood-light); }
    50%  { color: #ff0000;            }
    100% { color: var(--blood-light); }
  }
  @keyframes drip-fall {
    0%  { height: 0;    opacity: 1; }
    80% { height: 18px; opacity: 1; }
    100%{ height: 18px; opacity: 0; }
  }
</style>

<section id="credits">

  <h2 class="credits-title">✦ THE COOL CREW ✦</h2>
  <p class="credits-sub">— the people behind the nightmare —</p>

  <div class="crew-grid">
    {crew.map((member) => (
      <div class="crew-card">

        <div class="avatar-wrap">
          <img
            class="avatar-img"
            src={member.avatar}
            alt={member.name}
            width="80"
            height="80"
          />
          <div class="avatar-scanlines"></div>
        </div>

        <span class="crew-name">{member.name}</span>

        <span class="crew-role">{member.role}</span>

        <p class="crew-status">{member.status}</p>

        <div class="crew-socials">
          <a class="social-btn" href={member.socials.web}     title="web"  aria-label="website">W</a>
          <a class="social-btn" href={member.socials.twitter} title="twt"  aria-label="twitter">X</a>
          <a class="social-btn" href={member.socials.itch}    title="itch" aria-label="itch.io">🎮</a>
        </div>

      </div>
    ))}
  </div>

</section>

<script is:inline>
  function playErrorSound() {
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.type = 'square';
      osc.frequency.setValueAtTime(220, ctx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(110, ctx.currentTime + 0.15);
      gain.gain.setValueAtTime(0.3, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3);
      osc.start(ctx.currentTime);
      osc.stop(ctx.currentTime + 0.3);
    } catch(e) {}
  }

  function handleAddFriend(btn) {
    if (btn.classList.contains('blooded')) return;
    playErrorSound();
    btn.textContent = '✗ ERROR';
    btn.classList.add('blooded');
    setTimeout(() => { btn.textContent = '🩸 ADDED'; }, 400);
  }
</script>